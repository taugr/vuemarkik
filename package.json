{
  "name": "vuemarkik",
  "version": "1.2.1",
  "description": "Markdown rendering for Vue.js - extensible and customizable, powered by unified, remark, and rehype",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.2.2",
  "homepage": "https://vuemarkik.dev",
  "bugs": {
    "url": "https://github.com/taugr/vuemarkik/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/vuemarkik.git"
  },
  "author": "Tom Auger <tom@tau.gr>",
  "keywords": [
    "vue",
    "markdown",
    "rendering",
    "unified",
    "remark",
    "rehype"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "playground": "vite",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "pnpm -w run --parallel \"/^lint:(eslint|oxlint)$/\"",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:eslint:fix": "eslint . --fix",
    "lint:oxlint": "oxlint --deny-warnings",
    "lint:oxlint:fix": "oxlint --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "prepare": "husky",
    "quality": "pnpm -w run --parallel \"/^(lint|test:coverage)$/\""
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@shikijs/rehype": "^4.0.2",
    "@shikijs/vitepress-twoslash": "^4.0.2",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "katex": "^0.17.0",
    "lint-staged": "^17.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.58.2",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-group-icons": "^1.7.1",
    "vitepress-plugin-llms": "^1.11.1",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "hast-util-to-jsx-runtime": "^2.3.6",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
  }
}

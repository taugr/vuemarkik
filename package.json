{
  "name": "vuemarkik",
  "version": "1.1.0",
  "description": "Markdown rendering for Vue.js - extensible and customizable, powered by unified, remark, and rehype",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c",
  "homepage": "https://github.com/tom-auger/vuemarkik#readme",
  "bugs": {
    "url": "https://github.com/tom-auger/vuemarkik/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tom-auger/vuemarkik.git"
  },
  "author": "Tom Auger <tom@tau.gr>",
  "keywords": [
    "vue",
    "markdown",
    "rendering",
    "unified",
    "remark",
    "rehype"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "playground": "vite",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shikijs/rehype": "^4.0.2",
    "@shikijs/vitepress-twoslash": "^4.0.2",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "katex": "^0.16.38",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitepress": "2.0.0-alpha.12",
    "vitepress-plugin-group-icons": "^1.7.1",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
  }
}

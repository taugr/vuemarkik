{
  "name": "vuemarkik",
  "version": "1.2.1",
  "description": "Markdown rendering for Vue.js - extensible and customizable, powered by unified, remark, and rehype",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "homepage": "https://vuemarkik.dev",
  "bugs": {
    "url": "https://github.com/taugr/vuemarkik/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/vuemarkik.git"
  },
  "author": "Tom Auger <tom@tau.gr>",
  "keywords": [
    "vue",
    "markdown",
    "rendering",
    "unified",
    "remark",
    "rehype"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "playground": "vite",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "pnpm -w run --parallel \"/^lint:(eslint|oxlint)$/\"",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:eslint:fix": "eslint . --fix",
    "lint:oxlint": "oxlint --deny-warnings",
    "lint:oxlint:fix": "oxlint --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "prepare": "husky",
    "quality": "pnpm -w run --parallel \"/^(lint|test:coverage)$/\""
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@shikijs/rehype": "^4.2.0",
    "@shikijs/vitepress-twoslash": "^4.2.0",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "katex": "^0.17.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitepress-plugin-llms": "^1.13.1",
    "vitest": "^4.1.8",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.4"
  },
  "dependencies": {
    "hast-util-to-jsx-runtime": "^2.3.6",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
  }
}
